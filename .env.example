# Local example (PowerShell):
#   $env:DB_URL="jdbc:mysql://localhost:3306/bakery_db?useSSL=false&serverTimezone=UTC"
#   $env:DB_USERNAME="root"
#   $env:DB_PASSWORD="admin"
#   $env:JWT_SECRET="dev-insecure-change-me"
#   ./gradlew bootRun

PORT=8080

DB_URL=jdbc:mysql://localhost:3306/bakery_db?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=admin

# Use a long random string in production (>= 32 bytes).
JWT_SECRET=dev-insecure-change-me

# Access token expiration in milliseconds (optional).
JWT_EXPIRATION_MS=86400000

# Comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

SHOW_SQL=false

# update (dev) / validate (prod) / create-drop (tests)
HIBERNATE_DDL_AUTO=update

# Memory-related tuning (optional)
DB_POOL_MAX=10
DB_POOL_MIN_IDLE=0
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000
LAZY_INIT=false

# Swagger/OpenAPI in production (optional)
OPENAPI_ENABLED=true

# Pagination safety (optional)
PAGINATION_MAX_PAGE_SIZE=100
